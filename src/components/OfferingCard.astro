---
// OfferingCard.astro — The 6-month coaching package card
const PORTAL_URL = 'https://subdomain.practicebetter.io';

const includes = [
  '1 × 60-minute intake session',
  '5 × 30-minute follow-up appointments',
  'Personalized health plan tailored to your goals',
  'Access to client portal via Practice Better',
];
---

<div style="background:var(--color-bg); border:1px solid var(--color-border); border-radius:4px; overflow:hidden; max-width:640px; margin-inline:auto;">

  <!-- Accent header band -->
  <div style="background:var(--color-tomato-jam-500); padding:1.75rem 2rem;">
    <span class="section-label" style="color:rgba(255,255,255,0.7); margin-bottom:0.5rem;">Signature Offering</span>
    <h3 style="font-family:'Playfair Display',serif; font-size:1.75rem; font-weight:700; color:#fff; line-height:1.2;">
      6-Month Health Coaching Program
    </h3>
  </div>

  <!-- Body -->
  <div style="padding:2rem;">
    <p style="font-size:0.9375rem; color:var(--color-text-muted); line-height:1.7; margin-bottom:1.75rem;">
      A deeply personalized, six-month partnership designed to uncover the root causes of your health challenges and build a sustainable path forward — together.
    </p>

    <!-- What's included -->
    <h4 style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:500; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-text-muted); margin-bottom:1rem;">
      What's included
    </h4>

    <ul style="list-style:none; display:flex; flex-direction:column; gap:0.75rem; margin-bottom:2rem;" role="list">
      {includes.map(item => (
        <li style="display:flex; align-items:flex-start; gap:0.75rem; font-size:0.9375rem; color:var(--color-text-primary); line-height:1.5;">
          <!-- Accent bullet -->
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg"
               style="flex-shrink:0; margin-top:2px;" aria-hidden="true">
            <circle cx="9" cy="9" r="8.5" stroke="var(--color-tomato-jam-500)"/>
            <path d="M5.5 9l2.5 2.5L12.5 6.5" stroke="var(--color-tomato-jam-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {item}
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a
      href={PORTAL_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-primary"
      style="width:100%; justify-content:center;"
    >
      Book Your Intake Session
    </a>
  </div>
</div>
