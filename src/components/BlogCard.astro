---
// BlogCard.astro — Blog post card with hover lift
export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  author?: string;
}

const { title, description, pubDate, slug, author = 'Piretti Health' } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="blog-card rounded-sm overflow-hidden flex flex-col" style="background: var(--color-bg); border: 1px solid var(--color-border);">

  <!-- Card accent bar -->
  <div style="height:3px; background: var(--color-tomato-jam-500);"></div>

  <div class="p-8 flex flex-col flex-1 gap-4">
    <!-- Meta -->
    <div class="flex items-center gap-3">
      <time datetime={pubDate.toISOString()} style="font-size:0.8125rem; color:var(--color-text-muted); font-family:'DM Sans',sans-serif;">
        {formattedDate}
      </time>
      <span style="width:1px; height:12px; background:var(--color-border); display:inline-block;"></span>
      <span style="font-size:0.8125rem; color:var(--color-text-muted); font-family:'DM Sans',sans-serif;">{author}</span>
    </div>

    <!-- Title -->
    <h2 style="font-family:'Playfair Display',serif; font-size:1.375rem; font-weight:700; line-height:1.25; color:var(--color-text-primary);">
      <a href={`/blog/${slug}`}
         onmouseover="this.style.color='var(--color-accent)'"
         onmouseout="this.style.color='var(--color-text-primary)'"
         style="transition:color 150ms ease;">
        {title}
      </a>
    </h2>

    <!-- Excerpt -->
    <p style="font-size:0.9375rem; color:var(--color-text-muted); line-height:1.7; flex:1;">
      {description}
    </p>

    <!-- Read more -->
    <a
      href={`/blog/${slug}`}
      style="display:inline-flex; align-items:center; gap:0.375rem; font-size:0.875rem; font-weight:500; color:var(--color-accent); font-family:'DM Sans',sans-serif; transition:gap 150ms ease;"
      onmouseover="this.style.gap='0.625rem'"
      onmouseout="this.style.gap='0.375rem'"
    >
      Read more
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</article>
